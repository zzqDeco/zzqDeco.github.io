---
import { Github, Rss, Terminal } from 'lucide-astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  siteName: string;
  currentPath?: string;
  displayPath?: string;
}

const { siteName, currentPath = '/', displayPath = '~/blog' } = Astro.props;

const navItems = [
  { href: '/', label: 'home', path: 'index.astro' },
  { href: '/blog/', label: 'blog', path: 'posts.md' },
  { href: '/about/', label: 'about', path: 'about.md' },
];

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
};
---

<header class="site-header">
  <div class="titlebar" aria-label="editor titlebar">
    <div class="window-dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>

    <a class="brand-lockup" href="/" aria-label={`${siteName} 首页`}>
      <span class="brand-icon" aria-hidden="true">
        <Terminal size={17} strokeWidth={1.9} />
      </span>
      <span class="brand-text">
        <span class="brand-name">zzqdeco</span>
        <span class="brand-path">{displayPath}</span>
      </span>
    </a>

    <nav class="header-nav" aria-label="主导航">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          title={item.path}
        >
          <span>{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="header-tools">
      <a class="icon-button" href="/rss.xml" aria-label="RSS feed" title="RSS">
        <Rss size={16} strokeWidth={1.8} />
      </a>
      <a class="icon-button" href="https://github.com/zzqDeco" aria-label="GitHub profile" title="GitHub">
        <Github size={16} strokeWidth={1.8} />
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
