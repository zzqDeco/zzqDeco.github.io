---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  siteName: string;
}

const { siteName } = Astro.props;
---

<header class="site-header">
  <div class="container">
    <div class="header-shell">
      <div class="window-bar">
        <div class="window-dots" aria-hidden="true">
          <span class="window-dot is-danger"></span>
          <span class="window-dot is-warning"></span>
          <span class="window-dot is-success"></span>
        </div>
        <p class="window-title">$ cd ~/zzqDeco.github.io</p>
        <div class="header-status">
          <span>online</span>
          <span>zh-cn</span>
        </div>
      </div>

      <div class="header-inner">
        <a class="brand-block" href="/">
          <span class="brand-prefix">~/</span>
          <span class="brand">{siteName}</span>
        </a>

        <nav aria-label="主导航">
          <a href="/">$ ls home</a>
          <a href="/blog/">$ ls blog</a>
          <a href="/about/">$ cat about</a>
        </nav>

        <div class="header-tools">
          <ThemeToggle />
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    padding-top: 0.9rem;
    background: linear-gradient(180deg, color-mix(in srgb, var(--bg) 88%, transparent), transparent);
    backdrop-filter: blur(10px);
  }

  .header-shell {
    border: 1px solid var(--line);
    border-radius: 22px;
    overflow: hidden;
    background: color-mix(in srgb, var(--panel) 92%, transparent);
    box-shadow: var(--shadow);
  }

  .header-status {
    display: inline-flex;
    gap: 0.7rem;
    color: var(--muted);
    font-family: var(--mono-font);
    font-size: 0.76rem;
    text-transform: lowercase;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.82rem 1.1rem;
  }

  .brand-block {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
    color: var(--text);
    font-family: var(--mono-font);
  }

  .brand-prefix {
    color: var(--accent);
  }

  .brand {
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-width: 0;
  }

  nav a {
    display: inline-flex;
    align-items: center;
    padding: 0.36rem 0.58rem;
    border: 1px solid transparent;
    border-radius: 10px;
    color: var(--text-soft);
    font-family: var(--mono-font);
    font-size: 0.8rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  nav a:hover {
    color: var(--text);
    border-color: var(--line);
    background: color-mix(in srgb, var(--panel-soft) 78%, transparent);
    text-decoration: none;
  }

  .header-tools {
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 920px) {
    .header-inner {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 0.85rem;
    }

    nav {
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    .header-tools {
      justify-content: flex-start;
    }

    .header-status {
      display: none;
    }
  }
</style>
