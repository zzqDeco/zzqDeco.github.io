---
import { getGitHubProfile } from '../lib/githubProfile';

const profile = await getGitHubProfile();
const bioLines = profile.bio
  .split(/\r?\n/)
  .map((line) => line.trim())
  .filter(Boolean);
const bioPreview = bioLines.slice(0, 3);
const featuredRepos = profile.repos.slice(0, 2);
---

<aside class="profile-sidebar shell-window" aria-label="GitHub profile">
  <div class="window-bar">
    <div class="window-dots" aria-hidden="true">
      <span class="window-dot is-danger"></span>
      <span class="window-dot is-warning"></span>
      <span class="window-dot is-success"></span>
    </div>
    <p class="window-title">$ whoami</p>
    <p class="window-meta">profile</p>
  </div>

  <div class="profile-body">
    <div class="profile-identity">
      <a class="profile-avatar-link" href={profile.url} aria-label={`打开 ${profile.login} 的 GitHub 主页`}>
        <img class="profile-avatar" src={profile.avatarUrl} alt={`${profile.login} avatar`} width="96" height="96" loading="lazy" />
      </a>

      <div class="profile-copy">
        <p class="command-line">
          <span class="prompt">github@profile:~$</span>
          <span>gh user view {profile.login}</span>
        </p>

        <div class="profile-heading">
          <h2>{profile.name}</h2>
          <a class="profile-handle" href={profile.url}>@{profile.login}</a>
        </div>

        {bioPreview.length > 0 && (
          <div class="profile-bio">
            {bioPreview.map((line) => <p>{line}</p>)}
          </div>
        )}
      </div>
    </div>

    <div class="profile-fact-grid">
      {profile.company && (
        <div class="profile-fact">
          <span class="profile-fact-icon" aria-hidden="true">edu</span>
          <span class="profile-fact-label">campus</span>
          <span class="profile-fact-value">{profile.company}</span>
        </div>
      )}
      {profile.location && (
        <div class="profile-fact">
          <span class="profile-fact-icon" aria-hidden="true">geo</span>
          <span class="profile-fact-label">based in</span>
          <span class="profile-fact-value">{profile.location}</span>
        </div>
      )}
    </div>

    <div class="profile-stats" aria-label="GitHub stats">
      <div>
        <strong>{profile.publicRepos}</strong>
        <span>repos</span>
      </div>
      <div>
        <strong>{profile.followers}</strong>
        <span>followers</span>
      </div>
      <div>
        <strong>{profile.following}</strong>
        <span>following</span>
      </div>
      <div>
        <strong>{profile.stars}</strong>
        <span>stars</span>
      </div>
    </div>

    {featuredRepos.length > 0 && (
      <section class="profile-repos" aria-label="Pinned repositories">
        <p class="toc-label">$ ls pinned</p>
        <div class="profile-repo-list">
          {featuredRepos.map((repo) => (
            <a class="profile-repo" href={repo.url}>
              <span class="profile-repo-name">{repo.name}</span>
              <span class="profile-repo-description">{repo.description}</span>
              <span class="profile-repo-meta">
                {repo.language && <span>{repo.language}</span>}
                <span>{repo.stars} stars</span>
                <span>{repo.forks} forks</span>
              </span>
            </a>
          ))}
        </div>
        <a class="profile-more" href={profile.url}>View more on GitHub</a>
      </section>
    )}
  </div>
</aside>
