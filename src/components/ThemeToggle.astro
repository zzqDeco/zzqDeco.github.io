---
import { Moon, Sun } from 'lucide-astro';
---

<button id="theme-toggle" class="theme-toggle" type="button" aria-label="切换主题">
  <span class="theme-icon" aria-hidden="true">
    <Sun class="theme-sun" size={15} strokeWidth={1.9} />
    <Moon class="theme-moon" size={15} strokeWidth={1.9} />
  </span>
  <span class="theme-value" data-theme-value>light</span>
</button>

<script>
  const button = document.querySelector('#theme-toggle');
  const valueNode = button?.querySelector('[data-theme-value]');

  const getTheme = () =>
    document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';

  const updateButton = (theme) => {
    if (!button) return;
    if (valueNode) valueNode.textContent = theme;
    button.setAttribute('aria-label', `切换主题，当前为 ${theme}`);
    button.dataset.theme = theme;
  };

  const setTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem('theme', theme);
    updateButton(theme);
  };

  updateButton(getTheme());

  button?.addEventListener('click', () => {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  });
</script>
