<button id="theme-toggle" type="button" aria-label="切换主题">
  <span class="theme-label">mode</span>
  <span class="theme-value" data-theme-value>auto</span>
</button>

<script>
  const button = document.querySelector('#theme-toggle');
  const valueNode = button?.querySelector('[data-theme-value]');
  const labels = {
    light: 'paper',
    dark: 'matrix',
  };

  const getTheme = () =>
    document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';

  const updateButton = (theme) => {
    if (!button) return;
    const label = labels[theme];
    if (valueNode) valueNode.textContent = label;
    button.setAttribute('aria-label', `切换主题，当前为 ${label}`);
  };

  const setTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem('theme', theme);
    updateButton(theme);
  };

  updateButton(getTheme());

  button?.addEventListener('click', () => {
    setTheme(getTheme() === 'dark' ? 'light' : 'dark');
  });
</script>

<style>
  button {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    min-height: 2.1rem;
    padding: 0.34rem 0.72rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--panel-soft) 86%, transparent);
    color: var(--text);
    font: 0.76rem var(--mono-font);
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: border-color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  button:hover {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    background: color-mix(in srgb, var(--panel) 88%, transparent);
  }

  .theme-label {
    color: var(--muted);
    text-transform: uppercase;
  }

  .theme-value {
    display: inline-flex;
    align-items: center;
    gap: 0.34rem;
    color: var(--accent);
  }

  .theme-value::before {
    content: '>';
    font-size: 0.85em;
  }

  @media (max-width: 720px) {
    .theme-label {
      display: none;
    }
  }
</style>
