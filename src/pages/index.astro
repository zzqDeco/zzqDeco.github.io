---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ArrowRight, FileText, Rss, Sparkles, Terminal, UserRound } from 'lucide-astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => (
  import.meta.env.PROD ? data.draft !== true : true
))).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 5);
---

<BaseLayout title="首页" description="zzqDeco Blog 首页" variant="home">
  <section class="home-hero" aria-label="介绍">
    <div class="hero-console">
      <p class="terminal-line">
        <Terminal size={16} strokeWidth={1.8} aria-hidden="true" />
        <span class="prompt">$</span>
        <span>whoami --focus</span>
      </p>

      <h1 class="hero-title">Tech &amp; Life for Future</h1>
      <p class="hero-lede">
        从工作开始重新记录自己，努力成为一个合格的 Full-Stack AI Engineer &amp; Researcher。
      </p>

      <div class="hero-actions" aria-label="快捷链接">
        <a class="button-link button-link-primary" href="/blog/">
          <FileText size={16} strokeWidth={1.8} aria-hidden="true" />
          read posts
          <ArrowRight size={15} strokeWidth={1.8} aria-hidden="true" />
        </a>
        <a class="button-link" href="/about/">
          <UserRound size={16} strokeWidth={1.8} aria-hidden="true" />
          about me
        </a>
        <a class="button-link" href="/rss.xml">
          <Rss size={16} strokeWidth={1.8} aria-hidden="true" />
          rss
        </a>
      </div>
    </div>

    <aside class="hero-brief" aria-label="当前状态">
      <div class="brief-head">
        <Sparkles size={16} strokeWidth={1.8} aria-hidden="true" />
        <span>current buffer</span>
      </div>
      <dl class="brief-list">
        <div>
          <dt>role</dt>
          <dd>Full-Stack AI Engineer &amp; Researcher</dd>
        </div>
        <div>
          <dt>latest</dt>
          <dd>{latestPosts.length} entries loaded from Markdown</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="section-stack" aria-label="最近文章">
    <div class="section-head">
      <p class="section-label">recent posts</p>
      <a class="section-action" href="/blog/">
        view archive
        <ArrowRight size={14} strokeWidth={1.8} aria-hidden="true" />
      </a>
    </div>

    <ol class="post-list">
      {latestPosts.map((post) => (
        <li class="post-entry">
          <div class="post-entry-head">
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </time>
            <span class="sep">·</span>
            <span class="post-path">/blog/{post.id}</span>
          </div>
          <h3 class="post-entry-title"><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
          {post.data.description && (
            <p class="post-entry-summary">{post.data.description}</p>
          )}
          {post.data.tags.length > 0 && (
            <div class="post-entry-tags" aria-label="标签">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          )}
          <a class="post-entry-read" href={`/blog/${post.id}/`}>
            open file
            <ArrowRight size={13} strokeWidth={1.8} aria-hidden="true" />
          </a>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
