---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CalendarDays, Tags, Terminal, TableOfContents } from 'lucide-astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => (
    import.meta.env.PROD ? data.draft !== true : true
  ));

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const pubDate = post.data.pubDate.toLocaleDateString('zh-CN');
const updated = post.data.updatedDate?.toLocaleDateString('zh-CN');
const tocHeadings = headings.filter((heading) => heading.depth <= 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  variant="article"
  showToc={tocHeadings.length > 0}
>
  <article class:list={['article-page', tocHeadings.length > 0 && 'has-toc']}>
    <header class="article-head">
      <nav class="crumbs" aria-label="breadcrumbs">
        <a href="/">~</a>
        <span class="sep">/</span>
        <a href="/blog/">blog</a>
        <span class="sep">/</span>
        <span>{post.id}</span>
      </nav>

      <p class="terminal-line">
        <Terminal size={16} strokeWidth={1.8} aria-hidden="true" />
        <span class="prompt">$</span>
        <span>cat ./src/content/blog/{post.id}.md</span>
      </p>

      <h1 class="article-title">{post.data.title}</h1>
      {post.data.description && (
        <p class="article-description">{post.data.description}</p>
      )}

      <div class="article-meta" aria-label="文章元信息">
        <span>
          <CalendarDays size={14} strokeWidth={1.8} aria-hidden="true" />
          pub {pubDate}
        </span>
        {updated && <span>updated {updated}</span>}
        {post.data.tags.length > 0 && (
          <span class="article-tags">
            <Tags size={14} strokeWidth={1.8} aria-hidden="true" />
            {post.data.tags.map((tag) => <span>{tag}</span>)}
          </span>
        )}
      </div>
    </header>

    {tocHeadings.length > 0 && (
      <aside class="toc-panel" aria-label="目录">
        <p class="toc-head">
          <TableOfContents size={15} strokeWidth={1.8} aria-hidden="true" />
          sections
        </p>
        <ol>
          {tocHeadings.map((heading) => (
            <li class={`toc-depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </aside>
    )}

    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
